"""
One-time migration script to move existing database to Google Drive
"""

from pathlib import Path
from shutil import copy2
import os


def migrate_database():
    local_db = Path("data/time_tracker.db")
    gdrive_db = Path("G:/My Drive/App Development Files/G Drive DB/time_tracker.db")

    print("=" * 60)
    print("Time Tracker Database Migration to Google Drive")
    print("=" * 60)
    print()

    # Check if local database exists
    if not local_db.exists():
        print("✓ No local database found. Starting fresh in Google Drive.")
        return True

    # Check if Google Drive database already exists
    if gdrive_db.exists():
        response = input(f"⚠ Database already exists in Google Drive!\n"
                         f"  Do you want to overwrite it? (yes/no): ")
        if response.lower() != 'yes':
            print("Migration cancelled.")
            return False

    # Ensure Google Drive directory exists
    gdrive_db.parent.mkdir(parents=True, exist_ok=True)

    # Copy database
    print(f"Copying database from:")
    print(f"  {local_db.absolute()}")
    print(f"To:")
    print(f"  {gdrive_db.absolute()}")
    print()

    try:
        copy2(local_db, gdrive_db)
        print("✓ Database successfully migrated to Google Drive!")
        print()
        print("IMPORTANT:")
        print("  1. The local database still exists (for backup)")
        print("  2. The app will now use the Google Drive version")
        print("  3. Install Google Drive on other devices to sync")
        print("  4. Always close the app before switching devices")
        print()

        # Create backup of local
        backup_path = local_db.parent / f"time_tracker_backup_{local_db.stat().st_mtime:.0f}.db"
        copy2(local_db, backup_path)
        print(f"✓ Backup created: {backup_path}")

        return True

    except Exception as e:
        print(f"✗ Migration failed: {e}")
        return False


if __name__ == "__main__":
    migrate_database()
    input("\nPress Enter to exit...")
